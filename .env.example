# Environment Configuration Template
#
# ⚠ WARNING: This file contains examples with placeholder values.
# Do NOT commit actual secrets. Keep real values in .env (add to .gitignore).
#
# Copy this file to .env and update with your actual values:
#   cp .env.example .env
#   # Edit .env with real secrets
#   # Never commit .env to Git

# ============================================================================
# Database
# ============================================================================
# PostgreSQL connection string
# Dev Container: automatically set in docker-compose.yml
# Production: example format
DATABASE_URL=postgresql://app:app@localhost:5432/app

# ============================================================================
# Server
# ============================================================================
# HTTP server port (default: 3000)
PORT=3000

# Node environment (development, production)
NODE_ENV=development

# ============================================================================
# Authentication - MCP Server
# ============================================================================
# MCP endpoint bearer token (required for /mcp)
# Generate: openssl rand -hex 32
# IMPORTANT: Use strong random value. DO NOT commit.
MCP_BEARER_TOKEN=change-me-long-random-string

# ----------------------------------------------------------------------------
# MCP OAuth 2.1 (T4-2, optional)
# ----------------------------------------------------------------------------
# Externally reachable origin of this server (RFC 8414 issuer).
# When set, OAuth endpoints (/authorize /token /register /revoke and
# /.well-known metadata) are enabled and /mcp accepts OAuth access tokens
# in addition to MCP_BEARER_TOKEN (kept for clients without OAuth support,
# e.g. Codex CLI).
# Must be https:// (http allowed only for localhost testing). No query/fragment.
#OAUTH_ISSUER_URL=https://reader.example.com

# ============================================================================
# Authentication - Feed Collector
# ============================================================================
# POST /internal/collect endpoint authentication token
# Generate: openssl rand -hex 32
# IMPORTANT: Use strong random value. DO NOT commit.
# Used in: GitHub Actions secrets, Lambda environment, etc.
COLLECTOR_TOKEN=change-me-another-long-random-string

# ============================================================================
# Content Caching
# ============================================================================
# Whether to persist fetched article content to database
# false (default): fetch_article_content returns content but does NOT save
# true: saves to articles.content column (use with caution due to privacy)
CACHE_FULLTEXT=false

# ============================================================================
# Egress Proxy Trust (SSRF guard)
# ============================================================================
# Set to 'true' ONLY when all outbound traffic goes through an egress proxy
# with its own allowlist (e.g. this repo's Dev Container squid setup) and
# local DNS resolution is unavailable. Skips the DNS-based public-IP check
# in the SSRF guard; scheme / IP-literal / same-host-redirect checks remain.
# MUST be false (or unset) in environments with direct internet egress.
#
# IMPORTANT: When TRUST_EGRESS_PROXY=true, HTTPS_PROXY (or https_proxy) and
# HTTP_PROXY (or http_proxy) AND NODE_USE_ENV_PROXY=1 are all REQUIRED.
# The app validates this at startup (src/config.ts loadConfig) and refuses
# to start if any are missing -- otherwise traffic could bypass the proxy
# entirely and the SSRF guard would become a no-op.
TRUST_EGRESS_PROXY=false

# PT-003 (fail-closed): In NODE_ENV=production, running WITHOUT an egress proxy
# (TRUST_EGRESS_PROXY!=true) leaves the SSRF guard exposed to DNS rebinding
# (docs/004 §1). The app refuses to start in that configuration unless you
# explicitly accept the risk here. Prefer routing egress through the proxy;
# only set this to 'true' if you knowingly run direct egress in production.
#ALLOW_DIRECT_EGRESS=true

# Note (Dev Container only): Node's fetch ignores HTTP(S)_PROXY env vars by
# default. Start the server with NODE_USE_ENV_PROXY=1 to route feed/content
# fetching through squid:
#   NODE_USE_ENV_PROXY=1 node --env-file=.env src/main.ts
# WARNING: Do NOT put NODE_USE_ENV_PROXY=1 in this file. Node reads it only
# at process bootstrap, so an --env-file value passes the startup validation
# but does NOT actually enable the proxy. Always pass it from the shell.

# ============================================================================
# Browser Web UI (login at /, admin user created via /setup on first run)
# ============================================================================
# Secure attribute for the session cookie.
# Default: true when NODE_ENV=production (HTTPS terminator assumed).
# Set to false ONLY for plain-HTTP verification on a trusted network.
#SESSION_COOKIE_SECURE=true

# ============================================================================
# Deploy (compose.yaml) — read by docker compose, not by the app itself
# ============================================================================
# Required by compose.yaml. Generate: openssl rand -hex 16
#POSTGRES_PASSWORD=change-me-random-string
#POSTGRES_DB=rss
#POSTGRES_USER=rss
# Bind address/port for the app service (default 127.0.0.1:3000; see compose.yaml)
#APP_BIND=127.0.0.1
#APP_PORT=3000
# Interval for the optional collector-cron service (--profile cron)
#COLLECT_INTERVAL_SECONDS=900

# ============================================================================
# Contact Information
# ============================================================================
# Included in User-Agent header for RSS collection
# Examples:
#   your-email@example.com
#   https://github.com/your-org/your-repo/issues
#   +<your-phone> (if public contact info)
COLLECTOR_CONTACT=change-me-your-contact-info@example.com
