{
  "name": "personal-rss-reader",
  "version": "0.1.0",
  "private": true,
  "description": "パーソナルRSSリーダー + AIキュレーション (タイトル/URL/公開日時のみ収集、MCP経由でAIに公開)",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@hono/node-server": "2.0.8",
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.2.1",
    "hono": "4.12.30",
    "htmx.org": "2.0.10",
    "node-pg-migrate": "8.0.4",
    "pg": "8.22.0",
    "rss-parser": "3.13.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "typescript": "5.9.3"
  },
  "scripts": {
    "test": "node --test \"test/**/*.test.ts\"",
    "lint": "tsc --noEmit",
    "migrate": "node-pg-migrate up -m migrations",
    "migrate:down": "node-pg-migrate down -m migrations",
    "start": "node src/main.ts"
  }
}
